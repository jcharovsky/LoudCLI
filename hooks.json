{
  "claude-code": {
    "hooks": {
      "SessionStart": [
        {
          "matcher": "startup",
          "hooks": [
            {
              "type": "command",
              "command": "afplay ~/.claude/hooks/sounds/GLaDOS/Hello-2.aiff",
              "async": true
            }
          ]
        }
      ],
      "SessionEnd": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "afplay ~/.claude/hooks/sounds/GLaDOS/Bye-2.aiff"
            }
          ]
        }
      ],
      "UserPromptSubmit": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "~/.claude/hooks/on-prompt.sh",
              "async": true
            }
          ]
        }
      ],
      "Stop": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "~/.claude/hooks/on-stop.sh",
              "async": true
            }
          ]
        }
      ]
    }
  },
  "antigravity": {
    "copy": "Copy antigravity/hooks.json to ~/.gemini/config/hooks.json or merge its top-level hook definitions into an existing Antigravity hooks.json file."
  },
  "codex": {
    "copy": "Copy codex/hooks.json to ~/.codex/hooks.json or merge its hooks object into an existing Codex hooks.json file."
  }
}
